# Python artifacts
*.pyc
__pycache__/

# User's personal config and brain state (never ship)
.orion/
.orion-system/
orion_user_config.json
conversations/
knowledge/
memory/
graph_memory.json

# install.ps1 / install.sh write the user's machine-specific launcher here
bin/

# Visualizer runtime logs
interactive-visualizer/.viz.*.log

# Local scratch / driver scripts (prefix _ = local only).
# Exception: Python package markers (__init__.py) and dunder modules
# — these are real package source, not scratch. The original intent
# was to exclude leading-single-underscore driver scripts like
# _research_round2.py, not the dunder marker files.
_*.py
!**/__init__.py
!**/__main__.py

# Selfcheck apply backups
*.orion-bak

# OS + editor cruft
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Local environment + secrets
.env
.env.*
*.key
*.pem
credentials.json
